# Backend Configuration

# Required: LLM API Configuration
# For OpenAI: Get your API key from: https://platform.openai.com/api-keys
# For other providers: Use their OpenAI-compatible API key
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-proj-your-api-key-here
LLM_MODEL=gpt-5.4-2026-03-05
LLM_TEMPERATURE=0.0

# Optional: Backup LLM API Key (for automatic failover)
# Uses same LLM_BASE_URL and LLM_MODEL, only key differs
# Recommended: Use a different OpenAI account for redundancy
# BACKUP_LLM_API_KEY=sk-proj-your-backup-api-key-here

# Optional: Override default CORS origins
CORS_ORIGINS=http://localhost:3000

# Optional: Maximum file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Optional: PDF processor to use (default: pypdf)
# Options: pypdf, mineru
# Note: MinerU requires MINERU_API_KEY and AWS_S3_TEMP_BUCKET to be configured
PDF_PROCESSOR=pypdf

# Optional: MinerU API Configuration (for advanced PDF extraction)
# Get your API key from: https://mineru.net/
# When configured, system will try MinerU first and fallback to PyPDF on failure
# Features: OCR for scanned PDFs, formula recognition, table extraction
# Free tier: 2000 pages/day
# MINERU_API_KEY=your-mineru-api-key-here

# Optional: AWS S3 Temporary Storage (required for MinerU)
# S3 bucket name for temporary PDF storage (used by MinerU API)
# Example: metamate-pdf-temp
# AWS_S3_TEMP_BUCKET=your-s3-bucket-name
