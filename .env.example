# Backend Configuration

# Required: LLM API Configuration
# For OpenAI: Get your API key from: https://platform.openai.com/api-keys
# For other providers: Use their OpenAI-compatible API key
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-proj-your-api-key-here
LLM_MODEL=gpt-4.1-2025-04-14

# Optional: Override default CORS origins
CORS_ORIGINS=http://localhost:3000

# Optional: Maximum file size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Optional: PDF processor to use (default: pypdf)
# Options: pypdf, docling, mineru, mathpix, textract
PDF_PROCESSOR=pypdf